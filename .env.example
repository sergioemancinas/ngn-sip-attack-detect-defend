COMPOSE_PROJECT_NAME=ngn-sip

POSTGRES_DB=ngn_sip
POSTGRES_USER=ngn
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_MAJOR=16
PGVECTOR_VERSION=v0.8.0
PGVECTOR_COMMIT=2627c5ff775ae6d7aef0c430121ccf857842d2f2

SIP_DOMAIN=ngn.lab
DEV_BIND_IP=127.0.0.1
SIP_TRANSPORT_PORT=5060
RTP_PORT_MIN=30000
RTP_PORT_MAX=30100

ASTERISK_VERSION=20.19.0
ASTERISK_COMMIT=f66917fe6da487155f80ab50403bf3d7bdc86183
SIPP_VERSION=v3.7.3
SIPP_COMMIT=11b51748b274d24ac156ac40216600aca0f352a7

# Observability stack (docker-compose.observability.yml)
CLICKHOUSE_USER=ngn
CLICKHOUSE_PASSWORD=change-me-local-only
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-local-only

# Homer SIP capture stack (docker-compose.homer.yml). Local lab defaults; rotate on VM deploy.
HOMER_DB_PASSWORD=change-me-local-only
HOMER_ADMIN_PASSWORD=change-me-local-only

# Wazuh stack (docker-compose.wazuh.yml). Local lab defaults; rotate on deploy.
# Wazuh indexer renders internal_users hashes at startup from:
# - WAZUH_INDEXER_PASSWORD (admin)
# - WAZUH_DASHBOARD_PASSWORD (kibanaserver)
# NOTE: the Wazuh manager API enforces a password policy (>=8 chars with upper,
# lower, digit, and symbol). The indexer/API passwords below satisfy it; a plain
# "change-me-local-only" is rejected with "Error 5007 - Insecure user password".
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=ChangeMeLocal1!
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=ChangeMeLocal1!
WAZUH_DASHBOARD_USER=kibanaserver
WAZUH_DASHBOARD_PASSWORD=kibanaserver

# Keycloak stack + Wazuh OIDC (docker-compose.keycloak.yml + dashboard OIDC wiring).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-local-only
KEYCLOAK_REALM=ngn-sip-lab
KEYCLOAK_WAZUH_CLIENT_ID=wazuh-dashboard
KEYCLOAK_WAZUH_CLIENT_SECRET=change-me-local-only

# Dashboard SSO (Next.js, NextAuth keycloak provider). Leave KEYCLOAK_ISSUER
# empty to run the dashboard in local no-auth mode (DASHBOARD_ALLOW_INSECURE).
KEYCLOAK_ISSUER=http://localhost:8080/realms/ngn-sip-lab
KEYCLOAK_BROWSER_AUTH_URL=http://localhost:8080/realms/ngn-sip-lab/protocol/openid-connect/auth
KEYCLOAK_WELL_KNOWN_URL=http://keycloak:8080/realms/ngn-sip-lab/.well-known/openid-configuration
KEYCLOAK_CLIENT_SECRET=change-me-local-only
NEXTAUTH_URL=http://localhost:3002
# Generate a real secret with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-local-only
# true = local no-auth dev mode (works out of the box). Set false and run
# scripts/setup_keycloak_sso_clients.sh to enforce Keycloak SSO on the dashboard.
DASHBOARD_ALLOW_INSECURE=true

# SOC tool SSO secrets (observability / soar / homer). Provision/rotate with:
#   bash scripts/setup_keycloak_sso_clients.sh
GRAFANA_OIDC_CLIENT_SECRET=change-me-local-only
SHUFFLE_SSO_REDIRECT_URL=http://localhost:3001
HOMER_OIDC_ENABLE=false
HOMER_OIDC_CLIENT_SECRET=change-me-local-only

# ML stack (docker-compose.ml.yml). Model is pulled on demand via 'make ml-pull'.
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
CLICKHOUSE_DATABASE=ngn_sip
POSTGRES_DSN=postgresql://ngn:change-me-local-only@postgres:5432/ngn_sip

# SOAR stack (docker-compose.soar.yml). Local lab defaults; rotate before VM deploy.
SHUFFLE_DEFAULT_USERNAME=admin
SHUFFLE_DEFAULT_PASSWORD=change-me-local-only
# NOTE: Shuffle 2.2.0 requires API keys >= 36 chars for Bearer auth; shorter
# values are stored but unusable (scripts/provision_shuffle.sh then falls back
# to session login). Set a 36+ char value before first boot to enable key auth.
SHUFFLE_DEFAULT_APIKEY=change-me-local-only-0123456789abcdef
SHUFFLE_ENCRYPTION_MODIFIER=change-me-local-only
# Keycloak client secret for Shuffle OIDC (setup_keycloak_sso_clients.sh +
# scripts/provision_shuffle.sh --sso).
SHUFFLE_OIDC_CLIENT_SECRET=change-me-local-only
# Stage-3 graded SOAR workflow tunables (written into the workflow variables by
# scripts/provision_shuffle.sh on every run; defaults shown).
#SOAR_DEDUP_WINDOW_SECONDS=300
#ATTACK_SCORE_BAN_THRESHOLD=0.85
#ATTACK_SCORE_LOW_THRESHOLD=0.55
#ML_ATTACK_SCORE_HIGH=0.90
#NOTIFY_WEBHOOK_URL=disabled
#SHUFFLE_SSO_REDIRECT_URL=http://localhost:3001
SHUFFLE_OPENSEARCH_USERNAME=admin
SHUFFLE_OPENSEARCH_PASSWORD=change-me-local-only
AUTH_FOR_ORBORUS=change-me-local-only
# kamcmd-relay: the Shuffle Stage-3 ban executor (soar/kamcmd-relay). The
# workflow presents this bearer token when POSTing a ban.
KAMCMD_BLOCK_RELAY_TOKEN=change-me-local-only
# Lab posture: allow banning RFC1918 sources (attacker containers live on the
# 172.x sip_lab bridge). Set to 0 for any internet-facing deployment.
RELAY_ALLOW_PRIVATE=1

