# NGN SIP Stack Dashboard
# Copy to .env and fill from repo root .env (never commit secrets).

# ClickHouse (server-side only, sip_lab network)
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=ngn
CLICKHOUSE_PASSWORD=${CLICKHOUSE_PASSWORD}
CLICKHOUSE_DATABASE=ngn_sip

# Keycloak OIDC (optional: leave KEYCLOAK_ISSUER empty for local no-auth mode).
# Split-horizon: KEYCLOAK_ISSUER is the browser-facing URL (validates the
# id_token `iss` claim), KEYCLOAK_BROWSER_AUTH_URL is where the browser is
# redirected for login, KEYCLOAK_WELL_KNOWN_URL is the in-cluster discovery
# endpoint the server uses for token/userinfo/jwks (keycloak:8080).
KEYCLOAK_ISSUER=http://localhost:8080/realms/ngn-sip-lab
KEYCLOAK_BROWSER_AUTH_URL=http://localhost:8080/realms/ngn-sip-lab/protocol/openid-connect/auth
KEYCLOAK_WELL_KNOWN_URL=http://keycloak:8080/realms/ngn-sip-lab/.well-known/openid-configuration
KEYCLOAK_CLIENT_ID=ngn-sip-dashboard
KEYCLOAK_CLIENT_SECRET=${KEYCLOAK_CLIENT_SECRET}

# NextAuth (required when OIDC enabled; generate with `openssl rand -base64 32`)
NEXTAUTH_URL=http://127.0.0.1:3002
NEXTAUTH_SECRET=${NEXTAUTH_SECRET}

# Loopback-only dev escape hatch: "true" skips auth entirely (SSH-tunnel demo).
# MUST be "false" (with KEYCLOAK_ISSUER + a real NEXTAUTH_SECRET set) before
# any non-loopback exposure.
DASHBOARD_ALLOW_INSECURE=true

# UI refresh interval (milliseconds)
DASHBOARD_REFRESH_MS=15000
