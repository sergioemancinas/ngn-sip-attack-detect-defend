          "rawSql": "SELECT\n  toFloat64(greatest(dateDiff('millisecond', event_time, now64(3)), 0)) AS latency_ms\nFROM ngn_sip.suricata_alerts\nWHERE $__timeFilter(event_time)\nORDER BY event_time DESC\nLIMIT 20000",
