{
  "realm": "ngn-sip-lab",
  "enabled": true,
  "displayName": "NGN SIP Lab",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 1800,
  "roles": {
    "realm": [
      {
        "name": "wazuh-admin",
        "description": "Realm role for Wazuh Dashboard administrators.",
        "composite": true,
        "composites": {
          "client": {
            "wazuh-dashboard": [
              "all_access"
            ]
          }
        }
      }
    ],
    "client": {
      "wazuh-dashboard": [
        {
          "name": "all_access",
          "description": "OpenSearch backend role for full Wazuh dashboard administration."
        }
      ]
    }
  },
  "clients": [
    {
      "clientId": "wazuh-dashboard",
      "name": "Wazuh Dashboard",
      "description": "OIDC client used by the Wazuh dashboard.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "change-me-local-only",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": true,
      "redirectUris": [
        "https://localhost:5601/*"
      ],
      "webOrigins": [
        "https://localhost:5601"
      ],
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "web-origins"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "wazuh-client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String",
            "usermodel.clientRoleMapping.clientId": "wazuh-dashboard"
          }
        }
      ]
    },
    {
      "clientId": "grafana",
      "name": "Grafana",
      "description": "Grafana observability dashboard - OIDC SSO via Keycloak (generic_oauth).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "change-me-local-only",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": true,
      "redirectUris": [
        "http://localhost:3000/login/generic_oauth"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "web-origins"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "ngn-sip-dashboard",
      "name": "NGN SIP Stack Dashboard",
      "description": "Next.js stack dashboard - OIDC SSO via Keycloak (NextAuth keycloak provider).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "change-me-local-only",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": true,
      "redirectUris": [
        "http://localhost:3002/api/auth/callback/keycloak",
        "http://127.0.0.1:3002/api/auth/callback/keycloak"
      ],
      "webOrigins": [
        "http://localhost:3002",
        "http://127.0.0.1:3002"
      ],
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "web-origins"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "lab-admin",
      "enabled": true,
      "email": "lab-admin@ngn-sip.lab",
      "emailVerified": true,
      "firstName": "Lab",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "change-me-local-only",
          "temporary": true
        }
      ],
      "realmRoles": [
        "wazuh-admin"
      ],
      "requiredActions": [
        "UPDATE_PASSWORD"
      ]
    }
  ]
}